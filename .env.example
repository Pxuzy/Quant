# Quant — 环境变量配置

# 应用
APP_NAME=Quant API
APP_ENV=local

# 数据库（SQLite / PostgreSQL）
# SQLite: sqlite:///./storage/quant.db
# PostgreSQL: postgresql+psycopg://user:pass@host:5432/quant
DATABASE_URL=sqlite:///./storage/quant.db

# DuckDB 数据湖路径
DUCKDB_PATH=./storage/quant.duckdb
DATA_LAKE_DIR=./storage/lake

# CORS 允许的域名（逗号分隔）
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# 并行修复任务数
QUANT_REPAIR_PARALLELISM=5

# 数据源 Token（按需配置）
# TUSHARE_TOKEN=
# BAOSTOCK_ACCOUNT=
# AKSHARE_ENABLE=1
