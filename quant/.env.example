# App
APP_NAME=Quant
APP_ENV=development
API_HOST=0.0.0.0
API_PORT=8011

# Database
# Local fallback:
DATABASE_URL=sqlite:///./storage/quant.db
# PostgreSQL example:
# DATABASE_URL=postgresql+psycopg://quant:quant@localhost:5432/quant

# Frontend
VITE_API_BASE_URL=http://127.0.0.1:8011
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# Data source defaults
DEFAULT_STOCK_SOURCE=auto
# Tushare stays disabled until a token is configured and the source is enabled.
TUSHARE_TOKEN=
# Stock SDK is a Node package declared in apps/web/package.json. Set this only
# to load node_modules/stock-sdk from a custom directory before enabling it.
# STOCK_SDK_CWD=../apps/web
# STOCK_SDK_NODE=node

# Data lake
DATA_LAKE_DIR=./storage/lake
